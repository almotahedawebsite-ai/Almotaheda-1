rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is an admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'gemeslaim10@gmail.com' ||
        request.auth.token.email == 'almotahedawebsite@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // --- PUBLIC READ, ADMIN WRITE ---
    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /key_clients/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /branches/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /entities/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /slugs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- CREATED BY ANYONE, READ/MANAGED BY ADMIN OR OWNER ---
    match /bookings/{docId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.customerUid);
      allow update, delete: if isAdmin();
    }
    match /payments/{docId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.customerUid);
      allow update, delete: if isAdmin();
    }
    match /messages/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- ADMIN ONLY ---
    match /contracts/{docId} {
      allow read, write: if isAdmin();
    }
    match /admins/{emailId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == emailId);
      allow write: if isAdmin() || (request.auth != null && request.auth.token.email == 'gemeslaim10@gmail.com');
    }
    match /clients/{uid} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // --- Store Orders ---
    match /orders/{docId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow update, delete: if isAdmin();
    }
  }
}
